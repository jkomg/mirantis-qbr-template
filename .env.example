# Salesforce credentials — copy to .env and fill in.
# .env is gitignored; never commit real values.
#
# ---------------------------------------------------------------------------
# OAuth (recommended for multi-user / TAM laptops)
# ---------------------------------------------------------------------------
# Each person clicks "Connect to Salesforce" in the Configurator and logs in
# with their own identity. Only the Connected App keys go in .env — not passwords.
#
# IT setup (one-time):
#   1. Setup → App Manager → New Connected App
#   2. Enable OAuth, callback URL: http://localhost:8081/oauth/callback
#   3. Scopes: api, refresh_token
#   4. Permitted users: admin-approved or self-authorize (your org policy)
#   5. Copy Consumer Key + Consumer Secret below
#
SF_CONSUMER_KEY=
SF_CONSUMER_SECRET=
SF_REDIRECT_URI=http://localhost:8081/oauth/callback
SF_AUTH_MODE=auto
# SF_OAUTH_SCOPES=api refresh_token
# CONFIGURATOR_URL=http://localhost:8080/QBR%20Configurator.dc.html
# FLASK_SECRET_KEY=change-me-to-a-long-random-string

# DOMAIN:
#   login  →  production org
#   test   →  any sandbox
SF_DOMAIN=login

# ---------------------------------------------------------------------------
# Password flow (optional — CLI / legacy service account)
# ---------------------------------------------------------------------------
# Only needed if you are NOT using OAuth, or for `docker compose exec sf-sync python sync.py`.
# To get SECURITY_TOKEN: SF → Settings → Reset My Security Token (emailed to you).
#
# SF_USERNAME=service-account@example.com
# SF_PASSWORD=
# SF_SECURITY_TOKEN=

# Optional — version stamp written into payload._meta.source
SYNC_VERSION=v0.2
