# Salesforce credentials — copy to .env and fill in.
# .env is gitignored; never commit real values.
#
# To get the SECURITY_TOKEN:
#   Salesforce → top-right avatar → Settings → My Personal Information
#   → Reset My Security Token. SF emails it to you.
#
# DOMAIN:
#   login  →  production org
#   test   →  any sandbox

SF_USERNAME=tam-bot@mirantis.com.example
SF_PASSWORD=
SF_SECURITY_TOKEN=
SF_DOMAIN=login

# Optional — version stamp written into payload._meta.source
SYNC_VERSION=v0.1
